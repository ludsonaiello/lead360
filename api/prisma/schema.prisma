  // Conversational UX phrases (Sprint Voice-UX-01 - 2026-02-27)
  recovery_messages     Json? // When STT fails / empty input
  filler_phrases        Json? // Before tool execution
  long_wait_messages    Json? // During long tool execution (>20s)
  system_error_messages Json? // Generic system errors

  // Per-tool usage instruction overrides (Sprint Tool-Audit)
  // JSON object: { "general_rules": "...", "find_lead": "...", ... }
