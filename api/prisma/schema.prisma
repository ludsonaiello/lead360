  from_number                String    @db.VarChar(20)
  to_number                  String    @db.VarChar(20)
  direction                  String    @default("inbound") @db.VarChar(10)
  language_used              String?   @db.VarChar(10)
  intent                     String?   @db.VarChar(50)
  status                     String    @default("in_progress") @db.VarChar(20)
  outcome                    String?   @db.VarChar(50)
  is_overage                 Boolean   @default(false)
  duration_seconds           Int?
  transcript_summary         String?   @db.Text
  full_transcript            String?   @db.LongText
  actions_taken              String?   @db.Text
  lead_id                    String?   @db.VarChar(36)
  transferred_to             String?   @db.VarChar(20)
  stt_provider_id            String?   @db.VarChar(36)
  llm_provider_id            String?   @db.VarChar(36)
  tts_provider_id            String?   @db.VarChar(36)
  error_message              String?   @db.Text
  recording_url              String?   @db.VarChar(500)
  recording_duration_seconds Int?
  recording_status           String    @default("pending") @db.VarChar(30)
  transcription_status       String    @default("pending") @db.VarChar(30)
