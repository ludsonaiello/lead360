  labor_cost_per_unit       Decimal  @default(0) @db.Decimal(10, 2)
  equipment_cost_per_unit   Decimal  @default(0) @db.Decimal(10, 2)
  subcontract_cost_per_unit Decimal  @default(0) @db.Decimal(10, 2)
  other_cost_per_unit       Decimal  @default(0) @db.Decimal(10, 2)
  order_index               Int      @default(0)
  created_at                DateTime @default(now())

  quote_bundle     quote_bundle     @relation(fields: [quote_bundle_id], references: [id], onDelete: Cascade)
  unit_measurement unit_measurement @relation(fields: [unit_measurement_id], references: [id], onDelete: Restrict)

  @@index([quote_bundle_id, order_index])
  @@map("quote_bundle_item")
}

// SMS Templates (Sprint 3)
model sms_template {
  id            String   @id @default(uuid()) @db.VarChar(36)
  tenant_id     String   @db.VarChar(36)
  name          String   @db.VarChar(100)
  description   String?  @db.VarChar(255)
  template_body String   @db.Text
  category      String?  @db.VarChar(50)
  is_active     Boolean  @default(true)
  is_default    Boolean  @default(false)
  usage_count   Int      @default(0)
  created_by    String   @db.VarChar(36)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  // Relations
  tenant  tenant @relation("sms_template_tenant", fields: [tenant_id], references: [id], onDelete: Cascade)
  creator user   @relation("sms_template_creator", fields: [created_by], references: [id])

  @@index([tenant_id, is_active])
  @@index([tenant_id, category])
  @@map("sms_template")
}

