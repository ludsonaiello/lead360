  custom_profit_percent       Decimal?     @db.Decimal(5, 2)
  custom_overhead_percent     Decimal?     @db.Decimal(5, 2)
  custom_contingency_percent  Decimal?     @db.Decimal(5, 2)
  custom_tax_rate             Decimal?     @db.Decimal(5, 2)
