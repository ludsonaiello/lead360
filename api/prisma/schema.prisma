  @@index([tenant_id, status])
  @@index([phone_number])
  @@map("office_number_whitelist")
}

model call_transcription {
  id                          String    @id @default(uuid()) @db.VarChar(36)
  tenant_id                   String?   @db.VarChar(36) // Nullable for system-level
  call_record_id              String    @db.VarChar(36) // Removed @unique to allow retries
  transcription_provider      String    @db.VarChar(50) // 'openai_whisper' | 'oracle' | 'assemblyai'
  status                      String    @default("queued") @db.VarChar(20) // 'queued' | 'processing' | 'completed' | 'failed'
  transcription_text          String?   @db.Text // Full-text searchable (merged speaker-labeled transcript)
  // Dual-channel transcription fields
  channel_count               Int?      @db.TinyInt // 1 = mono (legacy), 2 = stereo
  speaker_1_transcription     String?   @db.Text // Channel 1 full transcription with timestamps (JSON)
  speaker_2_transcription     String?   @db.Text // Channel 2 full transcription with timestamps (JSON)
  speaker_1_label             String?   @db.VarChar(50) // e.g., "Business", "Lead", "Maria Silva"
  speaker_2_label             String?   @db.VarChar(50) // e.g., "Lead", "Business", "John Doe"
  language_requested          String?   @db.VarChar(10) // Language code sent to provider (from tenant setting)
  language_detected           String?   @db.VarChar(10) // ISO code
  confidence_score            Decimal?  @db.Decimal(3, 2)
  processing_duration_seconds Int?
  cost                        Decimal?  @db.Decimal(10, 4)
  error_message               String?   @db.Text
  // Retry/versioning fields
  is_current                  Boolean   @default(true) // Only the latest/active transcription is true
  retry_count                 Int       @default(0) // Number of retries (0 = first attempt)
  previous_transcription_id   String?   @db.VarChar(36) // Points to the transcription this one replaces
  created_at                  DateTime  @default(now())
  completed_at                DateTime?

  // Relations
  tenant      tenant?     @relation("tenant_call_transcriptions", fields: [tenant_id], references: [id], onDelete: Cascade)
  call_record call_record @relation(fields: [call_record_id], references: [id], onDelete: Cascade)

  // Indexes
  @@index([tenant_id, status])
  @@index([call_record_id])
  @@index([call_record_id, is_current]) // Fast lookup for current transcription
  @@fulltext([transcription_text]) // Full-text search index
  @@map("call_transcription")
}

model transcription_provider_configuration {
  id                 String   @id @default(uuid()) @db.VarChar(36)
  tenant_id          String?  @db.VarChar(36) // Nullable for system-level providers
  provider_name      String   @db.VarChar(50) // 'openai_whisper' | 'oracle' | 'assemblyai' | 'deepgram'
  is_system_default  Boolean  @default(false)
  status             String   @default("active") @db.VarChar(20) // 'active' | 'inactive'
