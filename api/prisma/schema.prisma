// ============================================================================

// ============================================================================
// ADMIN MODULE - Twilio Usage Tracking & System Health Monitoring
// ============================================================================

/// Stores usage data synced from Twilio API for billing and cost tracking
/// Enables nightly sync of communication costs across all tenants
/// Supports AC-18: Usage tracking pulls data from Twilio API and syncs nightly
model twilio_usage_record {
  id        String  @id @db.VarChar(36)
  tenant_id String? @db.VarChar(36)

  /// Category of usage: 'calls', 'sms', 'recordings', 'transcriptions'
  category String @db.VarChar(50)

  /// Number of units consumed in this period
  count Int @default(0)

  /// Unit of measurement: 'calls', 'messages', 'minutes', 'MB'
  usage_unit String @db.VarChar(20)

  /// Cost for this usage period in USD
  price Decimal @db.Decimal(10, 4)

  /// Currency unit (typically 'USD')
  price_unit String @db.VarChar(10)

  /// Start of usage period
  start_date DateTime

  /// End of usage period
  end_date DateTime

  /// Timestamp when data was synced from Twilio API
  synced_at DateTime @default(now())

  created_at DateTime @default(now())

  tenant tenant? @relation("twilio_usage_tenant", fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, start_date(sort: Desc)])
  @@index([category, start_date(sort: Desc)])
  @@index([tenant_id, category, start_date(sort: Desc)])
  @@index([synced_at(sort: Desc)])
  @@map("twilio_usage_record")
}

/// Tracks system health checks for monitoring and alerting
/// Enables proactive detection of API failures and performance degradation
/// Runs comprehensive checks every 15 minutes
model system_health_check {
  id String @id @db.VarChar(36)

  /// Type of health check: 'twilio_api', 'webhook_delivery', 'transcription_provider'
  check_type String @db.VarChar(100)

  /// Health status: 'HEALTHY', 'DEGRADED', 'DOWN'
  status String @db.VarChar(20)

  /// API response time in milliseconds (for performance tracking)
  response_time_ms Int?

  /// Error message if check failed
  error_message String? @db.Text

  /// Additional metadata about the health check (JSON)
  details Json?

  /// Timestamp when health check was performed
  checked_at DateTime @default(now())

  @@index([check_type, checked_at(sort: Desc)])
  @@index([status, checked_at(sort: Desc)])
  @@index([check_type, status, checked_at(sort: Desc)])
  @@index([checked_at(sort: Desc)])
  @@map("system_health_check")
}

/// Stores system alerts for admin notification
/// Enables alerting on system failures, quota issues, and failed operations
/// Supports acknowledgement workflow for admin tracking
model admin_alert {
  id String @id @db.VarChar(36)

  /// Alert category: 'SYSTEM_HEALTH', 'FAILED_TRANSCRIPTION', 'QUOTA_EXCEEDED', 'HIGH_USAGE'
  type String @db.VarChar(100)

  /// Alert priority: 'LOW', 'MEDIUM', 'HIGH', 'CRITICAL'
  severity String @db.VarChar(20)

  /// Human-readable alert message
  message String @db.Text

  /// Additional context data (JSON)
  details Json?

  /// Whether admin has addressed the alert
  acknowledged Boolean @default(false)

  /// Admin user who acknowledged the alert
  acknowledged_by String? @db.VarChar(36)

  /// Timestamp when alert was acknowledged
  acknowledged_at DateTime?

  /// Admin comment when acknowledging alert
  comment String? @db.Text

  /// Whether alert has been resolved
  resolved Boolean @default(false)

  /// Admin user who resolved the alert
  resolved_by String? @db.VarChar(36)

  /// Timestamp when alert was resolved
  resolved_at DateTime?

  /// Resolution notes
  resolution String? @db.Text

  created_at DateTime @default(now())

  acknowledged_by_user user? @relation("alert_acknowledged_by", fields: [acknowledged_by], references: [id], onDelete: SetNull)
  resolved_by_user     user? @relation("alert_resolved_by", fields: [resolved_by], references: [id], onDelete: SetNull)

  @@index([severity, acknowledged, created_at(sort: Desc)])
  @@index([type, severity, created_at(sort: Desc)])
  @@index([acknowledged, created_at(sort: Desc)])
  @@index([created_at(sort: Desc)])
  @@map("admin_alert")
}

