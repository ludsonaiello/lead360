generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model audit_log {
  id            String               @id @db.VarChar(36)
  tenant_id     String?              @db.VarChar(36)
  actor_user_id String?              @db.VarChar(36)
  actor_type    audit_log_actor_type
  entity_type   String               @db.VarChar(50)
  entity_id     String               @db.VarChar(36)
  description   String               @db.Text
  action_type   String               @db.VarChar(50)
  before_json   String?              @db.LongText
  after_json    String?              @db.LongText
  metadata_json String?              @db.LongText
  ip_address    String?              @db.VarChar(45)
  user_agent    String?              @db.VarChar(500)
  status        audit_log_status     @default(success)
  error_message String?              @db.Text
  created_at    DateTime             @default(now())
  user          user?                @relation(fields: [actor_user_id], references: [id])
  tenant        tenant?              @relation(fields: [tenant_id], references: [id])

  @@index([action_type], map: "audit_log_action_idx")
  @@index([actor_type])
  @@index([actor_user_id])
  @@index([entity_type, entity_id])
  @@index([status])
  @@index([tenant_id, created_at])
  @@index([tenant_id, status, created_at(sort: Desc)], map: "audit_log_tenant_status_created_idx")
}

model file {
  id                                                          String             @id @db.VarChar(36)
  tenant_id                                                   String             @db.VarChar(36)
  file_id                                                     String             @unique @db.VarChar(36)
  original_filename                                           String             @db.VarChar(255)
  mime_type                                                   String             @db.VarChar(100)
  size_bytes                                                  Int
  original_size_bytes                                         Int?
  category                                                    String             @db.VarChar(50)
  storage_path                                                String             @db.VarChar(500)
  storage_provider                                            String             @default("local") @db.VarChar(20)
  s3_bucket                                                   String?            @db.VarChar(100)
  s3_key                                                      String?            @db.VarChar(500)
  s3_region                                                   String?            @db.VarChar(50)
  uploaded_by                                                 String             @db.VarChar(36)
  entity_type                                                 String?            @db.VarChar(50)
  entity_id                                                   String?            @db.VarChar(36)
  is_orphan                                                   Boolean            @default(false)
  orphaned_at                                                 DateTime?
  is_trashed                                                  Boolean            @default(false)
  trashed_at                                                  DateTime?
  has_thumbnail                                               Boolean            @default(false)
  thumbnail_path                                              String?            @db.VarChar(500)
  thumbnail_s3_key                                            String?            @db.VarChar(500)
  is_optimized                                                Boolean            @default(false)
  optimization_quality                                        Int?               @db.TinyInt
  width                                                       Int?
  height                                                      Int?
  page_count                                                  Int?
  created_at                                                  DateTime           @default(now())
  updated_at                                                  DateTime           @updatedAt
  tenant_file_tenant_idTotenant                               tenant             @relation("file_tenant_idTotenant", fields: [tenant_id], references: [id], onDelete: Cascade)
  user                                                        user               @relation(fields: [uploaded_by], references: [id])
  tenant_tenant_logo_file_idTofile                            tenant[]           @relation("tenant_logo_file_idTofile")
  tenant_tenant_venmo_qr_code_file_idTofile                   tenant[]           @relation("tenant_venmo_qr_code_file_idTofile")
  tenant_insurance_tenant_insurance_gl_document_file_idTofile tenant_insurance[] @relation("tenant_insurance_gl_document_file_idTofile")
  tenant_insurance_tenant_insurance_wc_document_file_idTofile tenant_insurance[] @relation("tenant_insurance_wc_document_file_idTofile")
  tenant_license                                              tenant_license[]
  file_share_links                                            file_share_link[]

  @@index([file_id])
  @@index([tenant_id, category])
  @@index([tenant_id, is_orphan])
  @@index([tenant_id, is_trashed])
  @@index([storage_provider], map: "file_storage_provider_idx")
  @@index([has_thumbnail], map: "file_has_thumbnail_idx")
  @@index([is_optimized], map: "file_is_optimized_idx")
  @@index([uploaded_by], map: "file_uploaded_by_fkey")
}

model license_type {
  id             String           @id @db.VarChar(36)
  name           String           @unique @db.VarChar(100)
  description    String?          @db.Text
  is_active      Boolean          @default(true)
  created_at     DateTime         @default(now())
  updated_at     DateTime
  tenant_license tenant_license[]

  @@index([is_active])
}

model industry {
  id                String            @id @default(uuid()) @db.VarChar(36)
  name              String            @unique @db.VarChar(100)
  description       String?           @db.Text
  is_active         Boolean           @default(true)
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt
  tenant_industries tenant_industry[]

  @@index([is_active])
  @@index([name])
  @@map("industry")
}

model tenant_industry {
  id          String   @id @default(uuid()) @db.VarChar(36)
  tenant_id   String   @db.VarChar(36)
  industry_id String   @db.VarChar(36)
  created_at  DateTime @default(now())

  tenant   tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  industry industry @relation(fields: [industry_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, industry_id])
  @@index([tenant_id])
  @@index([industry_id])
  @@map("tenant_industry")
}

model module {
  id           String       @id @db.VarChar(36)
  name         String       @unique @db.VarChar(50)
  display_name String       @db.VarChar(100)
  description  String?      @db.VarChar(500)
  is_active    Boolean      @default(true)
  sort_order   Int          @default(0)
  icon         String?      @db.VarChar(50)
  created_at   DateTime     @default(now())
  updated_at   DateTime     @default(now())
  permission   permission[]

  @@index([is_active])
  @@index([name])
  @@index([sort_order])
}

model permission {
  id                       String                     @id @db.VarChar(36)
  module_id                String                     @db.VarChar(36)
  action                   String                     @db.VarChar(50)
  display_name             String                     @db.VarChar(100)
  description              String?                    @db.VarChar(500)
  is_active                Boolean                    @default(true)
  created_at               DateTime                   @default(now())
  updated_at               DateTime                   @default(now())
  module                   module                     @relation(fields: [module_id], references: [id], onDelete: Cascade)
  role_permission          role_permission[]
  role_template_permission role_template_permission[]

  @@unique([module_id, action], map: "module_action_unique")
  @@index([is_active])
  @@index([module_id])
}

model refresh_token {
  id          String    @id @db.VarChar(36)
  user_id     String    @db.VarChar(36)
  token_hash  String    @db.VarChar(255)
  device_name String?   @db.VarChar(255)
  ip_address  String?   @db.VarChar(45)
  user_agent  String?   @db.VarChar(500)
  expires_at  DateTime
  created_at  DateTime  @default(now())
  revoked_at  DateTime?
  user        user      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([token_hash])
  @@index([user_id, expires_at])
  @@index([user_id, revoked_at])
}

model role {
  id                 String            @id @db.VarChar(36)
  name               String            @unique @db.VarChar(50)
  description        String?           @db.VarChar(255)
  is_system          Boolean           @default(false)
  created_at         DateTime          @default(now())
  updated_at         DateTime
  is_active          Boolean           @default(true)
  created_by_user_id String?           @db.VarChar(36)
  deleted_at         DateTime?
  role_permission    role_permission[]
  user_role          user_role[]

  @@index([is_system], map: "is_system")
  @@index([name], map: "name")
  @@index([is_active])
  @@index([is_system])
  @@index([name])
}

model role_permission {
  id                 String     @id @db.VarChar(36)
  role_id            String     @db.VarChar(36)
  permission_id      String     @db.VarChar(36)
  granted_at         DateTime   @default(now())
  granted_by_user_id String?    @db.VarChar(36)
  created_at         DateTime   @default(now())
  updated_at         DateTime   @default(now())
  permission         permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)
  role               role       @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@unique([role_id, permission_id], map: "role_permission_unique")
  @@index([permission_id])
  @@index([role_id])
}

model role_template {
  id                       String                     @id @db.VarChar(36)
  name                     String                     @unique @db.VarChar(100)
  description              String?                    @db.Text
  is_system_template       Boolean                    @default(false)
  is_active                Boolean                    @default(true)
  created_by_user_id       String?                    @db.VarChar(36)
  created_at               DateTime                   @default(now())
  updated_at               DateTime                   @default(now())
  role_template_permission role_template_permission[]

  @@index([is_active])
  @@index([is_system_template])
}

model role_template_permission {
  id               String        @id @db.VarChar(36)
  role_template_id String        @db.VarChar(36)
  permission_id    String        @db.VarChar(36)
  created_at       DateTime      @default(now())
  permission       permission    @relation(fields: [permission_id], references: [id], onDelete: Cascade)
  role_template    role_template @relation(fields: [role_template_id], references: [id], onDelete: Cascade)

  @@unique([role_template_id, permission_id], map: "role_template_permission_unique")
  @@index([permission_id])
  @@index([role_template_id])
}

model service {
  id             String           @id @db.VarChar(36)
  name           String           @unique @db.VarChar(100)
  slug           String           @unique @db.VarChar(100)
  description    String?          @db.VarChar(500)
  is_active      Boolean          @default(true)
  created_at     DateTime         @default(now())
  updated_at     DateTime
  tenant_service tenant_service[]

  @@index([is_active])
  @@index([slug])
}

model subscription_plan {
  id             String   @id @db.VarChar(36)
  name           String   @unique @db.VarChar(100)
  description    String?  @db.Text
  monthly_price  Decimal  @db.Decimal(10, 2)
  annual_price   Decimal  @db.Decimal(10, 2)
  max_users      Int
  max_storage_gb Decimal? @db.Decimal(10, 2)
  offers_trial   Boolean  @default(false)
  trial_days     Int?
  feature_flags  String   @db.LongText
  is_active      Boolean  @default(true)
  is_default     Boolean  @default(false)
  created_at     DateTime @default(now())
  updated_at     DateTime
  tenant         tenant[]

  @@index([is_active])
  @@index([is_default])
  @@index([offers_trial])
}

model tenant {
  id                                      String                  @id @db.VarChar(36)
  subdomain                               String                  @unique @db.VarChar(63)
  company_name                            String                  @db.VarChar(200)
  is_active                               Boolean                 @default(true)
  legal_business_name                     String                  @db.VarChar(200)
  dba_name                                String?                 @db.VarChar(200)
  business_entity_type                    String                  @db.VarChar(50)
  state_of_registration                   String                  @db.VarChar(2)
  date_of_incorporation                   DateTime?
  ein                                     String                  @unique @db.VarChar(10)
  state_tax_id                            String?                 @db.VarChar(50)
  sales_tax_permit                        String?                 @db.VarChar(50)
  primary_contact_phone                   String                  @db.VarChar(20)
  secondary_phone                         String?                 @db.VarChar(20)
  primary_contact_email                   String                  @db.VarChar(255)
  support_email                           String?                 @db.VarChar(255)
  billing_email                           String?                 @db.VarChar(255)
  website_url                             String?                 @db.VarChar(255)
  instagram_url                           String?                 @db.VarChar(255)
  facebook_url                            String?                 @db.VarChar(255)
  tiktok_url                              String?                 @db.VarChar(255)
  youtube_url                             String?                 @db.VarChar(255)
  bank_name                               String?                 @db.VarChar(100)
  routing_number                          String?                 @db.VarChar(9)
  account_number                          String?                 @db.VarChar(50)
  account_type                            String?                 @db.VarChar(20)
  venmo_username                          String?                 @db.VarChar(50)
  venmo_qr_code_file_id                   String?                 @db.VarChar(36)
  logo_file_id                            String?                 @db.VarChar(36)
  primary_brand_color                     String?                 @db.VarChar(7)
  secondary_brand_color                   String?                 @db.VarChar(7)
  accent_color                            String?                 @db.VarChar(7)
  invoice_prefix                          String                  @default("INV") @db.VarChar(10)
  next_invoice_number                     Int                     @default(1)
  quote_prefix                            String                  @default("Q-") @db.VarChar(10)
  next_quote_number                       Int                     @default(1)
  default_quote_validity_days             Int                     @default(30)
  default_quote_terms                     String?                 @db.Text
  default_quote_footer                    String?                 @db.Text
  default_invoice_footer                  String?                 @db.Text
  default_payment_instructions            String?                 @db.Text
  timezone                                String                  @default("America/New_York") @db.VarChar(50)
  subscription_plan_id                    String?                 @db.VarChar(36)
  subscription_status                     String                  @default("trial") @db.VarChar(20)
  trial_end_date                          DateTime?
  billing_cycle                           String?                 @db.VarChar(20)
  next_billing_date                       DateTime?
  created_at                              DateTime                @default(now())
  updated_at                              DateTime
  deleted_at                              DateTime?
  default_contingency_rate                Decimal?                @db.Decimal(5, 2)
  default_overhead_rate                   Decimal?                @db.Decimal(5, 2)
  default_profit_margin                   Decimal?                @db.Decimal(5, 2)
  sales_tax_rate                          Decimal?                @db.Decimal(5, 3)
  business_size                           String?                 @db.VarChar(20)
  audit_log                               audit_log[]
  file_file_tenant_idTotenant             file[]                  @relation("file_tenant_idTotenant")
  file_tenant_logo_file_idTofile          file?                   @relation("tenant_logo_file_idTofile", fields: [logo_file_id], references: [file_id])
  subscription_plan                       subscription_plan?      @relation(fields: [subscription_plan_id], references: [id])
  file_tenant_venmo_qr_code_file_idTofile file?                   @relation("tenant_venmo_qr_code_file_idTofile", fields: [venmo_qr_code_file_id], references: [file_id])
  tenant_industries                       tenant_industry[]
  tenant_address                          tenant_address[]
  tenant_business_hours                   tenant_business_hours?
  tenant_custom_hours                     tenant_custom_hours[]
  tenant_insurance                        tenant_insurance?
  tenant_license                          tenant_license[]
  tenant_payment_terms                    tenant_payment_terms?
  tenant_service                          tenant_service[]
  tenant_service_area                     tenant_service_area[]
  user                                    user[]
  user_role                               user_role[]
  file_share_links                        file_share_link[]
  storage_config                          storage_config?
  impersonation_sessions                  impersonation_session[]
  leads                                   lead[]
  service_requests                        service_request[]
  webhook_api_keys                        webhook_api_key[]
  tenant_email_configs                    tenant_email_config[]
  email_templates                         email_template[]
  communication_events                    communication_event[]
  notifications                           notification[]
  notification_rules                      notification_rule[]

  @@index([ein])
  @@index([is_active])
  @@index([logo_file_id], map: "tenant_logo_file_id_fkey")
  @@index([subdomain])
  @@index([subscription_plan_id])
  @@index([subscription_status])
  @@index([trial_end_date])
  @@index([venmo_qr_code_file_id], map: "tenant_venmo_qr_code_file_id_fkey")
}

model tenant_address {
  id           String   @id @db.VarChar(36)
  tenant_id    String   @db.VarChar(36)
  address_type String   @db.VarChar(20)
  line1        String   @db.VarChar(255)
  line2        String?  @db.VarChar(255)
  city         String   @db.VarChar(100)
  state        String   @db.VarChar(2)
  zip_code     String   @db.VarChar(10)
  country      String   @default("USA") @db.VarChar(3)
  lat          Decimal? @db.Decimal(10, 8)
  long         Decimal? @db.Decimal(11, 8)
  is_po_box    Boolean  @default(false)
  is_default   Boolean  @default(false)
  created_at   DateTime @default(now())
  updated_at   DateTime
  tenant       tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, address_type])
  @@index([tenant_id, is_default])
}

model tenant_business_hours {
  id               String   @id @db.VarChar(36)
  tenant_id        String   @unique @db.VarChar(36)
  monday_closed    Boolean  @default(false)
  monday_open1     String?  @db.VarChar(5)
  monday_close1    String?  @db.VarChar(5)
  monday_open2     String?  @db.VarChar(5)
  monday_close2    String?  @db.VarChar(5)
  tuesday_closed   Boolean  @default(false)
  tuesday_open1    String?  @db.VarChar(5)
  tuesday_close1   String?  @db.VarChar(5)
  tuesday_open2    String?  @db.VarChar(5)
  tuesday_close2   String?  @db.VarChar(5)
  wednesday_closed Boolean  @default(false)
  wednesday_open1  String?  @db.VarChar(5)
  wednesday_close1 String?  @db.VarChar(5)
  wednesday_open2  String?  @db.VarChar(5)
  wednesday_close2 String?  @db.VarChar(5)
  thursday_closed  Boolean  @default(false)
  thursday_open1   String?  @db.VarChar(5)
  thursday_close1  String?  @db.VarChar(5)
  thursday_open2   String?  @db.VarChar(5)
  thursday_close2  String?  @db.VarChar(5)
  friday_closed    Boolean  @default(false)
  friday_open1     String?  @db.VarChar(5)
  friday_close1    String?  @db.VarChar(5)
  friday_open2     String?  @db.VarChar(5)
  friday_close2    String?  @db.VarChar(5)
  saturday_closed  Boolean  @default(true)
  saturday_open1   String?  @db.VarChar(5)
  saturday_close1  String?  @db.VarChar(5)
  saturday_open2   String?  @db.VarChar(5)
  saturday_close2  String?  @db.VarChar(5)
  sunday_closed    Boolean  @default(true)
  sunday_open1     String?  @db.VarChar(5)
  sunday_close1    String?  @db.VarChar(5)
  sunday_open2     String?  @db.VarChar(5)
  sunday_close2    String?  @db.VarChar(5)
  created_at       DateTime @default(now())
  updated_at       DateTime
  tenant           tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
}

model tenant_custom_hours {
  id          String   @id @db.VarChar(36)
  tenant_id   String   @db.VarChar(36)
  date        DateTime @db.Date
  reason      String   @db.VarChar(255)
  closed      Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime
  close_time1 String?  @db.VarChar(5)
  close_time2 String?  @db.VarChar(5)
  open_time1  String?  @db.VarChar(5)
  open_time2  String?  @db.VarChar(5)
  tenant      tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, date])
  @@index([tenant_id, date])
}

model tenant_insurance {
  id                                              String    @id @db.VarChar(36)
  tenant_id                                       String    @unique @db.VarChar(36)
  gl_insurance_provider                           String?   @db.VarChar(100)
  gl_policy_number                                String?   @db.VarChar(100)
  gl_coverage_amount                              Decimal?  @db.Decimal(12, 2)
  gl_effective_date                               DateTime?
  gl_expiry_date                                  DateTime?
  gl_document_file_id                             String?   @db.VarChar(36)
  wc_insurance_provider                           String?   @db.VarChar(100)
  wc_policy_number                                String?   @db.VarChar(100)
  wc_coverage_amount                              Decimal?  @db.Decimal(12, 2)
  wc_effective_date                               DateTime?
  wc_expiry_date                                  DateTime?
  wc_document_file_id                             String?   @db.VarChar(36)
  created_at                                      DateTime  @default(now())
  updated_at                                      DateTime
  file_tenant_insurance_gl_document_file_idTofile file?     @relation("tenant_insurance_gl_document_file_idTofile", fields: [gl_document_file_id], references: [file_id])
  tenant                                          tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  file_tenant_insurance_wc_document_file_idTofile file?     @relation("tenant_insurance_wc_document_file_idTofile", fields: [wc_document_file_id], references: [file_id])

  @@index([gl_document_file_id], map: "tenant_insurance_gl_document_file_id_fkey")
  @@index([gl_expiry_date])
  @@index([wc_document_file_id], map: "tenant_insurance_wc_document_file_id_fkey")
  @@index([wc_expiry_date])
}

model tenant_license {
  id                  String        @id @db.VarChar(36)
  tenant_id           String        @db.VarChar(36)
  license_type_id     String?       @db.VarChar(36)
  custom_license_type String?       @db.VarChar(100)
  license_number      String        @db.VarChar(100)
  issuing_state       String        @db.VarChar(2)
  issue_date          DateTime?
  expiry_date         DateTime
  document_file_id    String?       @db.VarChar(36)
  created_at          DateTime      @default(now())
  updated_at          DateTime
  file                file?         @relation(fields: [document_file_id], references: [file_id])
  license_type        license_type? @relation(fields: [license_type_id], references: [id])
  tenant              tenant        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([document_file_id], map: "tenant_license_document_file_id_fkey")
  @@index([expiry_date])
  @@index([license_type_id], map: "tenant_license_license_type_id_fkey")
  @@index([tenant_id, expiry_date])
}

model tenant_payment_terms {
  id         String   @id @db.VarChar(36)
  tenant_id  String   @unique @db.VarChar(36)
  terms_json String   @db.LongText
  created_at DateTime @default(now())
  updated_at DateTime
  tenant     tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
}

model tenant_service {
  id         String   @id @db.VarChar(36)
  tenant_id  String   @db.VarChar(36)
  service_id String   @db.VarChar(36)
  created_at DateTime @default(now())
  service    service  @relation(fields: [service_id], references: [id], onDelete: Cascade)
  tenant     tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, service_id])
  @@index([service_id])
  @@index([tenant_id])
}

model tenant_service_area {
  id           String   @id @db.VarChar(36)
  tenant_id    String   @db.VarChar(36)
  type         String   @db.VarChar(20)
  value        String   @db.VarChar(100)
  latitude     Decimal  @db.Decimal(10, 8)
  longitude    Decimal  @db.Decimal(11, 8)
  radius_miles Decimal? @db.Decimal(5, 2)
  state        String?  @db.VarChar(2)
  created_at   DateTime @default(now())
  updated_at   DateTime
  city_name    String?  @db.VarChar(100)
  entire_state Boolean  @default(false)
  zipcode      String?  @db.VarChar(10)
  tenant       tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([latitude, longitude])
  @@index([tenant_id, type])
}

model user {
  id                                            String                  @id @db.VarChar(36)
  tenant_id                                     String?                 @db.VarChar(36)
  email                                         String                  @db.VarChar(255)
  password_hash                                 String                  @db.VarChar(255)
  first_name                                    String                  @db.VarChar(100)
  last_name                                     String                  @db.VarChar(100)
  phone                                         String?                 @db.VarChar(20)
  is_active                                     Boolean                 @default(false)
  is_platform_admin                             Boolean                 @default(false)
  email_verified                                Boolean                 @default(false)
  email_verified_at                             DateTime?
  activation_token                              String?                 @db.VarChar(255)
  activation_token_expires                      DateTime?
  password_reset_token                          String?                 @db.VarChar(255)
  password_reset_expires                        DateTime?
  last_login_at                                 DateTime?
  mfa_enabled                                   Boolean                 @default(false)
  mfa_secret                                    String?                 @db.VarChar(255)
  oauth_provider                                String?                 @db.VarChar(50)
  oauth_provider_id                             String?                 @db.VarChar(255)
  created_at                                    DateTime                @default(now())
  updated_at                                    DateTime
  deleted_at                                    DateTime?
  audit_log                                     audit_log[]
  file                                          file[]
  refresh_token                                 refresh_token[]
  tenant                                        tenant?                 @relation(fields: [tenant_id], references: [id])
  user_role_user_role_assigned_by_user_idTouser user_role[]             @relation("user_role_assigned_by_user_idTouser")
  user_role_user_role_user_idTouser             user_role[]             @relation("user_role_user_idTouser")
  user_signature                                user_signature?
  share_links                                   file_share_link[]
  feature_flags_updated                         feature_flag[]
  maintenance_modes_updated                     maintenance_mode[]
  system_settings_updated                       system_setting[]
  impersonation_sessions_as_admin               impersonation_session[] @relation("ImpersonatingAdmin")
  impersonation_sessions_as_target              impersonation_session[] @relation("ImpersonatedUser")
  export_jobs                                   export_job[]
  leads_created                                 lead[]                  @relation("lead_created_by_user")
  lead_notes                                    lead_note[]             @relation("lead_note_user")
  lead_activities                               lead_activity[]         @relation("lead_activity_user")
  webhook_api_keys_created                      webhook_api_key[]       @relation("webhook_api_key_created_by_user")
  communication_events                          communication_event[]   @relation("communication_event_user")
  notifications                                 notification[]          @relation("notification_user")

  @@unique([email, tenant_id])
  @@index([activation_token])
  @@index([email])
  @@index([oauth_provider, oauth_provider_id])
  @@index([password_reset_token])
  @@index([tenant_id, is_active])
}

model user_role {
