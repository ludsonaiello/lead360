model lead {
  id                      String    @id @db.VarChar(36)
  tenant_id               String    @db.VarChar(36)
  first_name              String    @db.VarChar(100)
  last_name               String    @db.VarChar(100)
  language_spoken         String    @default("EN") @db.VarChar(10)
  accept_sms              Boolean   @default(false)
  preferred_communication String    @default("email") @db.VarChar(20)
  status                  String    @default("lead") @db.VarChar(20)
  source                  String    @db.VarChar(20)
  external_source_id      String?   @db.VarChar(255)
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt
  created_by_user_id      String?   @db.VarChar(36)
  lost_reason             String?   @db.Text
  lost_at                 DateTime?

  // SMS Opt-Out Management (TCPA Compliance - Sprint 1)
  sms_opt_out        Boolean   @default(false)
  sms_opt_out_at     DateTime?
  sms_opt_in_at      DateTime?
  sms_opt_out_reason String?   @db.VarChar(255)

  tenant           tenant            @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  created_by_user  user?             @relation("lead_created_by_user", fields: [created_by_user_id], references: [id], onDelete: SetNull)
  emails           lead_email[]
  phones           lead_phone[]
  addresses        lead_address[]
  service_requests service_request[]
  notes            lead_note[]
  activities       lead_activity[]
  quotes           quote[]           @relation("quote_lead")
  call_records     call_record[]     @relation("lead_call_records")
  voice_call_logs  voice_call_log[]
  appointments     appointment[]

  @@index([tenant_id, status])
  @@index([tenant_id, created_at(sort: Desc)])
  @@index([tenant_id, external_source_id])
  @@index([tenant_id, updated_at(sort: Desc)])
  @@map("lead")
}

model lead_email {
  id         String   @id @db.VarChar(36)
  lead_id    String   @db.VarChar(36)
  email      String   @db.VarChar(255)
  is_primary Boolean  @default(false)
  created_at DateTime @default(now())

