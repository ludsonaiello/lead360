  quote_number                String       @db.VarChar(50)
  title                       String       @db.VarChar(200)
  status                      quote_status @default(draft)
  lead_id                     String?      @db.VarChar(36)
  vendor_id                   String?      @db.VarChar(36)
  jobsite_address_id          String       @db.VarChar(36)
