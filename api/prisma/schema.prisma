  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  tenant          tenant?                  @relation("quote_template_tenant", fields: [tenant_id], references: [id], onDelete: Cascade)
  created_by_user user?                    @relation("quote_template_creator", fields: [created_by_user_id], references: [id], onDelete: SetNull)
  category        template_category?       @relation("template_category", fields: [category_id], references: [id], onDelete: SetNull)
  source_template quote_template?          @relation("template_clones", fields: [source_template_id], references: [id], onDelete: SetNull)
  clones          quote_template[]         @relation("template_clones")
  quotes          quote[]
  tenants_using   tenant[]                 @relation("tenant_active_template")
  versions        quote_template_version[] @relation("template_versions")
  usage_logs      template_usage_log[]     @relation("template_usage")

  @@index([tenant_id])
  @@index([category_id])
  @@index([is_global, is_active])
  @@index([is_default])
