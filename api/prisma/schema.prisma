model call_record {
  id                         String    @id @default(uuid()) @db.VarChar(36)
  tenant_id                  String?   @db.VarChar(36) // Nullable for system-level calls
  lead_id                    String?   @db.VarChar(36) // Nullable until matched
  twilio_config_id           String?   @db.VarChar(36)
  twilio_call_sid            String    @unique @db.VarChar(100)
  direction                  String    @db.VarChar(20) // 'inbound' | 'outbound'
  from_number                String    @db.VarChar(20)
  to_number                  String    @db.VarChar(20)
  status                     String    @db.VarChar(20) // 'initiated' | 'ringing' | 'in_progress' | 'completed' | 'failed' | 'no_answer' | 'busy' | 'canceled'
  call_type                  String    @db.VarChar(30) // 'customer_call' | 'office_bypass_call' | 'ivr_routed_call'
  handled_by                 String    @default("direct") @db.VarChar(20) // 'direct' | 'ivr' | 'voice_ai' | 'office_bypass'
  voice_call_log_id          String?   @unique @db.VarChar(36) // FK to voice_call_log when handled by AI
  initiated_by               String?   @db.VarChar(36) // User ID if outbound
  call_reason                String?   @db.Text
  outcome                    String?   @db.VarChar(50) // Call outcome (matched to voice_call_log)
  duration_seconds           Int? // Total call duration in seconds (matched to voice_call_log)
  recording_url              String?   @db.VarChar(500)
  recording_duration_seconds Int?
  recording_status           String    @default("pending") @db.VarChar(30) // 'pending' | 'available' | 'processing_transcription' | 'transcribed' | 'failed'
  ivr_action_taken           Json?
  consent_message_played     Boolean   @default(false)
  cost                       Decimal?  @db.Decimal(10, 4)
  started_at                 DateTime?
  ended_at                   DateTime?
  created_at                 DateTime  @default(now())
  updated_at                 DateTime  @updatedAt

  // Relations
  tenant            tenant?              @relation("tenant_call_records", fields: [tenant_id], references: [id], onDelete: Cascade)
  lead              lead?                @relation("lead_call_records", fields: [lead_id], references: [id], onDelete: SetNull)
  initiated_by_user user?                @relation("user_initiated_calls", fields: [initiated_by], references: [id], onDelete: SetNull)
  transcriptions    call_transcription[] // One-to-many: allows retries
  voice_call_log    voice_call_log?      @relation("call_record_voice_log", fields: [voice_call_log_id], references: [id], onDelete: SetNull)

  // Indexes
  @@index([tenant_id, created_at])
  @@index([tenant_id, status])
  @@index([tenant_id, lead_id])
  @@index([tenant_id, outcome])
  @@index([tenant_id, handled_by])
  @@index([twilio_call_sid])
  @@index([from_number])
  @@index([to_number])
  @@index([recording_status])
  @@map("call_record")
}

model ivr_configuration {
  id               String   @id @default(uuid()) @db.VarChar(36)
