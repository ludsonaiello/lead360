  is_archived                 Boolean      @default(false)
  created_by_user_id          String?      @db.VarChar(36)
  created_at                  DateTime     @default(now())
  updated_at                  DateTime     @updatedAt
  latest_pdf_file_id          String?      @db.VarChar(36)
  parent_quote_id             String?      @db.VarChar(36)
  pdf_content_hash            String?      @db.VarChar(64)
  pdf_last_generated_at       DateTime?
  pdf_generation_params       Json?

  tenant          tenant                @relation("quote_tenant", fields: [tenant_id], references: [id], onDelete: Cascade)
  parent_quote    quote?                @relation("change_order_parent", fields: [parent_quote_id], references: [id], onDelete: Restrict)
  lead            lead?                 @relation("quote_lead", fields: [lead_id], references: [id], onDelete: SetNull)
  vendor          vendor?               @relation(fields: [vendor_id], references: [id], onDelete: SetNull)
  jobsite_address quote_jobsite_address @relation(fields: [jobsite_address_id], references: [id], onDelete: Restrict)
  active_template quote_template?       @relation(fields: [active_template_id], references: [id], onDelete: SetNull)
  created_by_user user?                 @relation("quote_creator", fields: [created_by_user_id], references: [id], onDelete: SetNull)
  latest_pdf_file file?                 @relation("quote_latest_pdf", fields: [latest_pdf_file_id], references: [id], onDelete: SetNull)

  versions            quote_version[]
  items               quote_item[]
  groups              quote_group[]
  approvals           quote_approval[]
  discount_rules      quote_discount_rule[]
  tag_assignments     quote_tag_assignment[]
  attachments         quote_attachment[]
  view_logs           quote_view_log[]
  download_logs       quote_download_log[]
  draw_schedule       draw_schedule_entry[]
  public_access       quote_public_access[]
  change_orders       quote[]                @relation("change_order_parent")
  notes               quote_note[]
  template_usage_logs template_usage_log[]   @relation("quote_template_usage")

  @@unique([tenant_id, quote_number])
  @@index([tenant_id, status])
  @@index([tenant_id, vendor_id])
  @@index([tenant_id, created_at(sort: Desc)])
  @@index([tenant_id, lead_id])
  @@index([tenant_id, expires_at])
  @@index([tenant_id, is_archived])
  @@index([tenant_id, parent_quote_id])
  @@index([status])
  @@index([latest_pdf_file_id])
  @@map("quote")
